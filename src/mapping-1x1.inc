map '@'-'_' $00
map 'a'-'z' $01
map ' '-'?' $20
map '{' $1e 
map '}' $1f

; Shape
map '□' $40 ; square
map '⬡' $41 ; hex

; Size
map 'Ⓣ' $42 ; tiny
map 'Ⓢ' $43 ; small
map 'Ⓜ' $44 ; medium
map 'Ⓑ' $45 ; big

; Difficulty
map 'Ⅰ' $46 ; easy
map 'Ⅱ' $47 ; normal
map 'Ⅲ' $48 ; hard

; Controller
map '🕹' $49 ; joystick
map '🖱' $4a ; mouse

; Lives
map '♥' $4b ; live
